{
  "架构": {
    "layers": 8,
    "init_channels": 16,
    "auxiliary": true,
    "auxiliary_weight": 0.4
  },

  "进化搜索": {
    "objectives": 2,
    "init_pop_size": 10,
    "population_size": 50,
    "generations": 20,
    "parent_pool_size": 10,
    "crossover_rounds": 5,
    "pc_layer": 0.5,
    "pm_layer": 0.15,
    "pm_edge": 0.3,
    "metric": "synflow",
    "seed": 42
  },

  "训练": {
    "epochs": 50,
    "learning_rate": 0.025,
    "min_learning_rate": 0.001,
    "momentum": 0.9,
    "weight_decay": 0.0003,
    "drop_path_prob": 0.2,
    "grad_clip": 5.0,
    "cutout": true,
    "cutout_length": 16
  },

  "数据": {
    "dataset": "cifar10",
    "data_root": "./data",
    "batch_size": 96,
    "eval_batch_size": 256,
    "num_workers": 2,
    "train_portion": 0.9
  },

  "系统": {
    "save_dir": "./results",
    "device": "cuda",
    "pin_memory": true,
    "print_freq": 50,
    "save_freq": 10
  }
}
